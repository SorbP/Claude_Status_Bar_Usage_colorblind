{
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/.claude && git pull --rebase origin master 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/.claude && git add settings.json .gitignore *.py projects/*/memory/ 2>/dev/null; git diff --staged --quiet || git commit -m \"Auto-save: $(date '+%Y-%m-%d %H:%M')\" && git push origin master 2>/dev/null || true",
            "async": true
          },
          {
            "type": "command",
            "command": "python ~/.claude/session_receipt.py",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"C:\\Program Files\\Python313\\python.exe\" \"C:\\Users\\ASUS-LAPTOP\\.claude\\usage_statusline.py\""
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "warp@claude-code-warp": true
  }
}
